FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 373.15;

boundaryField
{
    coldWall
    {
        type            fixedValue;
        value           uniform 360;
    }

    vapourReservoir
    {
        type            fixedValue;
        value           uniform 373.15;
    }

    bottom
    {
        type            symmetryPlane;
    }

    top
    {
        type            symmetryPlane;
    }

    frontAndBack
    {
        type            empty;
    }
}


